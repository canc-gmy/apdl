   "source": [
    "import matplotlib.pyplot as plt\n",
    "import matplotlib as mpl\n",
    "\n",
    "colors = mpl.colormaps['plasma'].colors\n",
    "\n",
    "fig, ax = plt.subplots(layout='constrained')\n",
    "\n",
    "for i, color in enumerate(colors):\n",
    "    print(color)\n",
    "    ax.plot([0, i], color=color)\n",
    "\n",
    "plt.show()"
   ]
  }
